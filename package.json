{
  "name": "@canopy-iiif/app-root",
  "version": "1.12.3",
  "description": "An open-source static site generator designed for fast creation, contextualization, and customization of a discovery-focused digital scholarship and collections website using IIIF APIs.",
  "private": true,
  "main": "app/scripts/canopy-build.mjs",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsx app/scripts/canopy-build.mts",
    "dev": "tsx app/scripts/canopy-build.mts",
    "preview:template": "node packages/helpers/template/preview-template.js --source packages/helpers/template --name template --out .template-preview",
    "preview:template-i18n": "node packages/helpers/template/preview-template.js --source packages/helpers/template-i18n --name template-i18n --out .template-i18n-preview",
    "preview:template-essay": "node packages/helpers/template/preview-template.js --source packages/helpers/template-essay --name template-essay --out .template-essay-preview",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand --config tests/jest.config.cjs",
    "precommit:tests": "npm run test:unit",
    "prepare": "husky install",
    "lint": "eslint --config configs/eslint.config.mjs .",
    "format": "prettier -c --config configs/prettier.config.cjs --ignore-path configs/prettierignore .",
    "format:write": "prettier -w --config configs/prettier.config.cjs --ignore-path configs/prettierignore .",
    "changeset": "node packages/helpers/run-changeset.js",
    "sync:locale": "node packages/helpers/locales/sync-default-locale.js",
    "version:packages": "node packages/helpers/version-bump.js",
    "release": "node packages/helpers/guard-publish.js && node packages/helpers/run-changeset.js publish"
  },
  "dependencies": {
    "@canopy-iiif/app": "^1.11.1",
    "@samvera/clover-iiif": "^3.7.0",
    "embla-carousel": "^8.6.0"
  },
  "optionalDependencies": {
    "@parcel/watcher-linux-x64-glibc": "^2.5.1",
    "@parcel/watcher-linux-x64-musl": "^2.5.1",
    "lightningcss-linux-x64-gnu": "^1.30.1",
    "lightningcss-linux-x64-musl": "^1.30.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@tailwindcss/cli": "^4.1.13",
    "@types/node": "^24.6.2",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "esbuild": "^0.21.4",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.13",
    "ts-jest": "^29.4.5",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0"
  },
  "author": "Mat Jordan <mat@northwestern.edu>",
  "homepage": "https://canopy-iiif.github.io/app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canopy-iiif/app.git",
    "directory": "packages/app"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}
